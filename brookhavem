-- Referências básicas
local playerGui = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")

-- Criando a tela (ScreenGui)
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "AvisoManutencao"
screenGui.IgnoreGuiInset = true -- Faz cobrir a tela toda, incluindo a barra superior
screenGui.Parent = playerGui

-- Criando o fundo cinza
local frame = Instance.new("Frame")
frame.Size = UDim2.new(1, 0, 1, 0) -- Ocupa 100% da largura e altura
frame.BackgroundColor3 = Color3.fromRGB(50, 50, 50) -- Cor cinza escuro
frame.BorderSizePixel = 0
frame.Parent = screenGui

-- Criando o texto
local label = Instance.new("TextLabel")
label.Size = UDim2.new(0.8, 0, 0.2, 0) -- Tamanho relativo
label.Position = UDim2.new(0.5, 0, 0.5, 0) -- Centralizado
label.AnchorPoint = Vector2.new(0.5, 0.5) -- Ponto de ancoragem no meio
label.BackgroundTransparency = 1 -- Fundo do texto invisível
label.Text = "O Nova Brookhaven vai ser atualizado por isso está off"
label.TextColor3 = Color3.fromRGB(255, 255, 255) -- Texto branco
label.TextScaled = true -- Ajusta o tamanho da fonte automaticamente
label.Font = Enum.Font.GothamBold -- Fonte moderna
label.Parent = frame
