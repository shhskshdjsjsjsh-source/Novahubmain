        scriptLoaded = true
    else
        notify("Nova Hub", "Erro ao carregar: " .. tostring(err), 5)
    end
elseif scripts[tostring(PlaceId)] then
    local scriptData = scripts[tostring(PlaceId)]
    notify("Nova Hub", "Carregando " .. scriptData.name .. "...", 3)
    
    local success, err = pcall(function()
        loadstring(game:HttpGet(scriptData.url))()
    end)
    
    if success then
        notify("Nova Hub", scriptData.name .. " carregado com sucesso!", 5)
        scriptLoaded = true
    else
        notify("Nova Hub", "Erro ao carregar: " .. tostring(err), 5)
    end
else
    notify("Nova Hub", "Nenhum script encontrado para este jogo (ID: " .. tostring(PlaceId) .. ")", 5)
end
