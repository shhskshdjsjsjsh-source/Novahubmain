elseif dandysWorldIds[PlaceId] then
    notify("Nova Hub", "Carregando Dandy's World...", 3)
    local success, err = pcall(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/shhskshdjsjsjsh-source/Novahubmain/refs/heads/main/Dandys-World"))()
    end)
    if success then
